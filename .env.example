# Non-secret configuration only. Copy to .env for local dev.
# Never put passwords, API keys, or tokens here — use Secret Manager.

TOOLS_GCP_PROJECT=tools-non-prod
TOOLS_GCP_REGION=us-central1
TOOLS_SECRET_NAME=tools-non-prod-app-config
TOOLS_ENVIRONMENT=nonprod

# Set to 1 to run locally without GCP (tests, offline dev)
# TOOLS_SKIP_GCP=1
