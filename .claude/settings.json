{
  "permissions": {
    "allow": [
      "Bash(make install)",
      "Bash(make dev)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(make ci)",
      "Bash(make verify)",
      "Bash(make smoke)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(pytest:*)",
      "Bash(pip-audit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(gcloud config get-value:*)",
      "Bash(gcloud * describe:*)",
      "Bash(gcloud * list:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform fmt:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/secret-scan.sh",
            "statusMessage": "Scanning for secrets…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/ruff-fix.sh",
            "statusMessage": "ruff --fix"
          }
        ]
      }
    ]
  }
}
